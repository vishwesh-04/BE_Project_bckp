# ============================================================
# server.env.example — copy to server.env and fill in values
# server.env is gitignored; never commit secrets.
# ============================================================

# Network / transport
SERVER_ADDRESS=0.0.0.0:45678
SERVER_DRIVER_ADDRESS=127.0.0.1:9091
CONTROL_API_HOST=0.0.0.0
CONTROL_API_PORT=8000
CONTROL_API_URL=http://127.0.0.1:8000
INFERENCE_API_HOST=0.0.0.0
INFERENCE_API_PORT=8001
INFERENCE_API_URL=http://127.0.0.1:8001
TLS_ENABLED=false
# TLS_CA_CERT=/app/certs/ca.pem
# TLS_SERVER_CERT=/app/certs/server.pem
# TLS_SERVER_KEY=/app/certs/server.key

# Control API auth — set a strong random secret; leave blank to disable auth (dev only)
AUTH_TOKEN=<your-secret-token-here>

# Optional held-out evaluation data on the server machine
GLOBAL_TESTING_SET=./data/global_test.csv

# Server orchestration
MIN_CLIENTS=3
READINESS_POLL_TIMEOUT_SECONDS=15
ORCHESTRATION_IDLE_SLEEP_SECONDS=1.0
TRAINING_SESSION_ROUNDS=4
QUORUM_WAIT_TIMEOUT=30.0
SESSION_COOLDOWN_SECONDS=300.0
SESSION_STALL_TIMEOUT_SECONDS=60.0
MAX_CLIENTS=999

# Shared preprocessing artifacts
COLUMNS_PATH=./preprocessing/columns.txt
SCALER_PATH=./preprocessing/scaler.pkl
MODEL_DIR=./models
ARTIFACT_DIR=./models
LOG_DIR=./logs
TRAINING_LOG_PATH=./logs/server-training.log
CONTROL_API_LOG_PATH=./logs/server-control-api.log

# Central DP — use a private seed, not a public one
CENTRAL_DP_ENABLED=true
DP_MAX_NORM=0.75
DP_NOISE_MULTIPLIER=0.35
DP_NOISE_SEED=<your-private-integer-seed>

# Flower SecAgg+
SECAGG_ENABLED=true
SECAGGPLUS_NUM_SHARES=1.0
SECAGGPLUS_RECONSTRUCTION_THRESHOLD=0.75
SECAGGPLUS_MAX_WEIGHT=1000.0
SECAGGPLUS_CLIPPING_RANGE=8.0
SECAGGPLUS_QUANTIZATION_RANGE=4194304
SECAGGPLUS_MODULUS_RANGE=4294967296
SECAGGPLUS_TIMEOUT_SECONDS=30

# Redis state store
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_USERNAME=
# REDIS_PASSWORD=<your-redis-password>
# REDIS_URL=
# REDIS_SSL=false
