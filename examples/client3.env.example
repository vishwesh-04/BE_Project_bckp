# Network / transport
#CLIENT_SERVER_ADDRESS=10.0.0.10:45678
TLS_ENABLED=false
# TLS_CA_CERT=/app/certs/ca.pem

# Client identity for Flower ClientApp deployment
CLIENT_ID=3
CLIENT_PERSONALIZE=true

# Local client dataset mounted on client machine 3
CLIENT_3_TRAINING_SET=/app/data/client_3_train.csv
CLIENT_3_TESTING_SET=/app/data/client_3_test.csv

# Client training/runtime
LOCAL_EPOCHS=3
BATCH_SIZE=32
LEARNING_RATE=0.001

# Shared preprocessing artifacts available on the client machine
COLUMNS_PATH=/app/preprocessing/columns.txt
SCALER_PATH=/app/preprocessing/scaler.pkl

# Privacy on client: local DP disabled
CLIENT_DP_ENABLED=false

# Flower SecAgg+
SECAGG_ENABLED=true
